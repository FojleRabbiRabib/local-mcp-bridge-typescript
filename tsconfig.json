{
    "compilerOptions":
    {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./build",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "forceConsistentCasingInFileNames": true
    },
    "include":
    [
        "src/**/*"
    ],
    "exclude":
    [
        "node_modules",
        "build",
        "src/__tests__",
        "**/*.test.ts"
    ]
}